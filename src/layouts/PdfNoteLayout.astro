---
export interface Props {
  title: string;
  pdfPath: string;
  sourceCodePath?: string;
  description?: string;
}

const { title, pdfPath, sourceCodePath, description } = Astro.props;
---

<html lang="zh-CN">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{title} | Suifeng Wudong</title>
		<style>
			:root {
				--bg-color: #ffffff;
				--sidebar-bg: #f8fafc;
				--text-color: #1e293b;
				--text-muted: #64748b;
				--accent-color: #0284c7;
				--border-color: #e2e8f0;
				--max-width: 1200px;
			}
			body {
				font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
				line-height: 1.6;
				margin: 0;
				padding: 0;
				background-color: var(--bg-color);
				color: var(--text-color);
			}
			.header {
				background: rgba(255, 255, 255, 0.8);
				backdrop-filter: blur(8px);
				padding: 1rem 2rem;
				border-bottom: 1px solid var(--border-color);
				display: flex;
				justify-content: space-between;
				align-items: center;
				position: sticky;
				top: 0;
				z-index: 100;
			}
			.logo {
				font-size: 1.25rem;
				font-weight: 700;
				color: var(--accent-color);
				text-decoration: none;
			}
			.nav-links {
				display: flex;
				gap: 2rem;
			}
			.nav-links a {
				color: var(--text-muted);
				text-decoration: none;
				font-weight: 500;
				transition: color 0.2s;
			}
			.nav-links a:hover {
				color: var(--accent-color);
			}
			.breadcrumb {
				padding: 1rem 2rem;
				background: var(--sidebar-bg);
				border-bottom: 1px solid var(--border-color);
				font-size: 0.875rem;
			}
			.breadcrumb a {
				color: var(--accent-color);
				text-decoration: none;
			}
			.breadcrumb a:hover {
				text-decoration: underline;
			}
			.sep {
				margin: 0 0.5rem;
				color: var(--text-muted);
			}
			.current {
				color: var(--text-color);
				font-weight: 500;
			}
			.nav-links-secondary {
				display: flex;
				justify-content: flex-end;
				padding: 0 2rem;
				gap: 1rem;
			}
			.nav-links-secondary a, .nav-links-secondary button {
				display: inline-flex;
				align-items: center;
				gap: 0.5rem;
				padding: 0.5rem 1rem;
				background: white;
				border: 1px solid var(--border-color);
				border-radius: 6px;
				color: var(--text-muted);
				text-decoration: none;
				font-size: 0.875rem;
				font-weight: 500;
				transition: all 0.2s;
				cursor: pointer;
			}
			.nav-links-secondary a:hover, .nav-links-secondary button:hover {
				border-color: var(--accent-color);
				color: var(--accent-color);
			}
			.nav-links-secondary button {
				font-family: inherit;
			}
			.container {
				max-width: var(--max-width);
				margin: 0 auto;
				padding: 2rem;
			}
			.pdf-container {
				background: white;
				border: 1px solid var(--border-color);
				border-radius: 12px;
				overflow: hidden;
				box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1);
			}
			.pdf-container iframe {
				width: 100%;
				height: 800px;
				border: none;
				border-radius: 12px;
			}
			.legacy-note {
				margin-top: 2rem;
				padding: 1rem;
				background: #fefce8;
				border: 1px solid #fef08a;
				border-radius: 6px;
				font-size: 0.9rem;
				color: #854d0e;
			}
			@media (max-width: 768px) {
				.pdf-container iframe {
					height: 600px;
				}
				.nav-links-secondary {
					flex-direction: column;
					align-items: stretch;
				}
			}
		</style>
	</head>
	<body>
		<header class="header">
			<a href="/" class="logo">Suifeng Wudong</a>
			<nav class="nav-links">
				<a href="/">Home</a>
				<a href="/notes">Notes</a>
				<a href="/about">About</a>
			</nav>
		</header>

		<div class="breadcrumb">
			<a href="/">Home</a>
			<span class="sep">/</span>
			<a href="/notes">Notes</a>
			<span class="sep">/</span>
			<span class="current">{title}</span>
		</div>

		<div class="nav-links-secondary">
			<a href={pdfPath} target="_blank" rel="noopener noreferrer"></a>
			<button id="fullscreen-btn">
				<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
					<path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/>
				</svg>
				全屏查看
			</button>
			{sourceCodePath && (                
				<a href={sourceCodePath} download>
					<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
						<path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M7 10l5 5 5-5M12 15V3"/>
					</svg>
					下载源码
				</a>
			)}
		</div>

		<main class="container">
			<div class="pdf-container">
				<iframe src={pdfPath} title={title}></iframe>
			</div>
			<div class="legacy-note">
				<strong>注：</strong>Typst HTML 实时渲染功能因官方实验性功能暂不成熟（数学公式解析限制）已转为 PDF 直读模式。
				{description && <p>{description}</p>}
			</div>
		</main>
		<script>
			document.getElementById('fullscreen-btn')?.addEventListener('click', function() {
				const iframe = document.querySelector('.pdf-container iframe') as HTMLIFrameElement;
				if (iframe?.requestFullscreen) {
					iframe.requestFullscreen();
				} else if ((iframe as any)?.webkitRequestFullscreen) { // Safari
					(iframe as any).webkitRequestFullscreen();
				} else if ((iframe as any)?.msRequestFullscreen) { // IE11
					(iframe as any).msRequestFullscreen();
				}
			});
		</script>
	</body>
</html>