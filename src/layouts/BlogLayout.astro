---
export interface Props {
  title: string;
  description?: string;
  pubDate?: string;
  author?: string;
  tags?: string[];
}

const { title, description, pubDate, author, tags } = Astro.props;
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Suifeng Wudong</title>
    <style>
      :root {
        --bg-color: #ffffff;
        --text-color: #1e293b;
        --text-muted: #64748b;
        --accent-color: #0284c7;
        --border-color: #e2e8f0;
        --max-width: 800px;
      }
      body {
        font-family:
          -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        line-height: 1.8;
        margin: 0;
        padding: 0;
        background-color: var(--bg-color);
        color: var(--text-color);
      }
      .header {
        background: rgba(255, 255, 255, 0.8);
        backdrop-filter: blur(8px);
        padding: 1rem 2rem;
        border-bottom: 1px solid var(--border-color);
        display: flex;
        justify-content: space-between;
        align-items: center;
        position: sticky;
        top: 0;
        z-index: 100;
      }
      .logo {
        font-size: 1.25rem;
        font-weight: 700;
        color: var(--accent-color);
        text-decoration: none;
      }
      .nav-links {
        display: flex;
        gap: 2rem;
      }
      .nav-links a {
        color: var(--text-muted);
        text-decoration: none;
        font-weight: 500;
        transition: color 0.2s;
      }
      .nav-links a:hover {
        color: var(--accent-color);
      }
      .breadcrumb {
        padding: 1rem 2rem;
        max-width: var(--max-width);
        margin: 0 auto;
        font-size: 0.875rem;
      }
      .breadcrumb a {
        color: var(--accent-color);
        text-decoration: none;
      }
      .sep {
        margin: 0 0.5rem;
        color: var(--text-muted);
      }
      .container {
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 2rem;
      }
      .blog-header {
        margin-bottom: 3rem;
        padding-bottom: 2rem;
        border-bottom: 1px solid var(--border-color);
      }
      .blog-header h1 {
        font-size: 2.5rem;
        margin: 0 0 1rem 0;
        line-height: 1.2;
        color: #0f172a;
      }
      .meta {
        display: flex;
        gap: 1.5rem;
        color: var(--text-muted);
        font-size: 0.875rem;
      }
      .tags {
        display: flex;
        gap: 0.5rem;
        margin-top: 1rem;
      }
      .tag {
        background: #f1f5f9;
        padding: 0.2rem 0.6rem;
        border-radius: 4px;
        font-size: 0.75rem;
        color: #475569;
      }
      .content :global(h2) {
        font-size: 1.75rem;
        margin: 2.5rem 0 1.25rem;
        color: #0f172a;
      }
      .content :global(h3) {
        font-size: 1.4rem;
        margin: 2rem 0 1rem;
        color: #1e293b;
      }
      .content :global(p) {
        margin-bottom: 1.25rem;
      }
      .content :global(code) {
        background: #f1f5f9;
        padding: 0.2rem 0.4rem;
        border-radius: 4px;
        font-family:
          ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
        font-size: 0.9em;
      }
      .content :global(pre) {
        background: #1e293b;
        color: #f8fafc;
        padding: 1.5rem;
        border-radius: 8px;
        overflow-x: auto;
        margin: 1.5rem 0;
      }
      /* Make code inside pre transparent so inline-code styles don't
         produce white boxes inside dark code blocks */
      .content :global(pre code) {
        background: transparent;
        padding: 0;
        border-radius: 0;
        color: inherit;
        font-family:
          ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
        font-size: inherit * 0.9;
      }
      .content :global(table) {
        width: 100%;
        border-collapse: collapse;
        margin: 1.5rem 0;
      }
      .content :global(th),
      .content :global(td) {
        border: 1px solid var(--border-color);
        padding: 0.75rem;
        text-align: left;
      }
      .content :global(th) {
        background: #f8fafc;
      }
    </style>
  </head>
  <body>
    <header class="header">
      <a href="/" class="logo">Suifeng Wudong</a>
      <nav class="nav-links">
        <a href="/">Home</a>
        <a href="/notes">Notes</a>
        <a href="/about">About</a>
      </nav>
    </header>

    <div class="breadcrumb">
      <a href="/">Home</a>
      <span class="sep">/</span>
      <a href="/notes">Notes</a>
      <span class="sep">/</span>
      <span class="current">Blog</span>
    </div>

    <main class="container">
      <article>
        <header class="blog-header">
          <h1>{title}</h1>
          <div class="meta">
            {pubDate && <span>发布于 {pubDate}</span>}
            {author && <span>作者：{author}</span>}
          </div>
          {
            tags && (
              <div class="tags">
                {tags.map((tag) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
            )
          }
        </header>
        <div class="content">
          <slot />
        </div>
      </article>
    </main>
  </body>
</html>
