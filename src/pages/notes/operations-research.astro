---
const title = "运筹学：确定性方法";
---

<html lang="zh-CN">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{title}</title>
	</head>
	<body>
		<div class="sidebar">
			<div class="sidebar-header">
				<h3>Guidance</h3>
			</div>
			<ul id="toc"></ul>
		</div>
		<div class="hrefs">
			<div class="breadcrumb">
				<a href="/">Home</a>
				<span class="sep">/</span>
				<a href="/notes">Notes</a>
				<span class="sep">/</span>
				<span class="current">Operations Research</span>
			</div>
			<div class="nav-links">
				<a href="/about">About</a>
			</div>
		</div>
		<main>
			<div class="container">
				<h1 id="doc-title">{title}</h1>
				<div class="content-meta">
					<a href="/pdfs/operations-research.pdf" target="_blank" class="download-btn">
						<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M7 10l5 5 5-5M12 15V3"/></svg>
						阅读完整 PDF 笔记 (推荐)
					</a>
					<a href="/notes/simplex.c" download class="dl-secondary">
						<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M7 10l5 5 5-5M12 15V3"/></svg>
						算法源码 (C)
					</a>
				</div>
				<div class="content" id="content-div">
					<div class="pdf-container">
						<iframe src="/pdfs/operations-research.pdf" width="100%" height="800px" style="border: none; border-radius: 8px; box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1);"></iframe>
					</div>
					<div class="legacy-note" style="margin-top: 2rem; padding: 1rem; background: #fefce8; border: 1px solid #fef08a; border-radius: 6px; font-size: 0.9rem; color: #854d0e;">
						注：Typst HTML 实时渲染功能因官方实验性功能暂不成熟（数学公式解析限制）已转为 PDF 直读模式。
					</div>
				</div>
			</div>
		</main>
		<script>
			// Removed dynamic TOC generation for PDF mode
		</script>
		<style>
			:root {
				--bg-color: #ffffff;
				--sidebar-bg: #f8fafc;
				--sidebar-item-hover: #f1f5f9;
				--text-color: #1e293b;
				--text-muted: #64748b;
				--accent-color: #0284c7;
				--sidebar-width: 0; /* PDF mode - hide sidebar for now */
				--header-height: 56px;
				--border-color: #e2e8f0;
				--content-width: 900px;
			}
			body {
				margin: 0;
				padding: 0;
				background-color: #f1f5f9;
				color: var(--text-color);
				font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
			}
			.sidebar {
				display: none;
			}
			.hrefs {
				position: fixed;
				top: 0;
				left: 0;
				right: 0;
				height: var(--header-height);
				background: rgba(255, 255, 255, 0.9);
				backdrop-filter: blur(8px);
				z-index: 100;
				display: flex;
				align-items: center;
				justify-content: space-between;
				padding: 0 2rem;
				border-bottom: 1px solid var(--border-color);
			}
			.breadcrumb {
				display: flex;
				align-items: center;
				gap: 0.75rem;
				font-size: 0.875rem;
				color: var(--text-muted);
			}
			.breadcrumb a {
				color: var(--text-muted);
				text-decoration: none;
			}
			.breadcrumb .sep { color: #cbd5e1; }
			.breadcrumb .current { color: var(--text-color); font-weight: 500; }
			.nav-links a {
				color: var(--text-muted);
				text-decoration: none;
				font-size: 0.875rem;
				margin-left: 1.5rem;
				font-weight: 500;
			}

			main {
				padding-top: var(--header-height);
			}
			.container {
				max-width: var(--content-width);
				margin: 2rem auto;
				padding: 0 2rem;
			}
			h1 {
				font-size: 2.25rem;
				font-weight: 800;
				margin-bottom: 1.5rem;
				color: #0f172a;
			}
			.content-meta {
				display: flex;
				gap: 1rem;
				margin-bottom: 2rem;
			}
			.download-btn {
				background: var(--accent-color);
				color: white !important;
				padding: 0.6rem 1.2rem;
				border-radius: 8px;
				text-decoration: none;
				display: inline-flex;
				align-items: center;
				gap: 0.5rem;
				font-weight: 600;
				transition: transform 0.2s;
			}
			.download-btn:hover { transform: translateY(-1px); }
			.dl-secondary {
				background: white;
				border: 1px solid var(--border-color);
				padding: 0.6rem 1.2rem;
				border-radius: 8px;
				text-decoration: none;
				display: inline-flex;
				align-items: center;
				gap: 0.5rem;
				color: var(--text-muted) !important;
			}
			.pdf-container {
				background: white;
				border-radius: 12px;
				padding: 10px;
				box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.1);
			}
		</style>
	</body>
</html>