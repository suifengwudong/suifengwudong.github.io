---
const title = "Home";

// Fetch GitHub repositories
const response = await fetch('https://api.github.com/users/suifengwudong/repos?sort=stars&per_page=6');
const repos = await response.json();

// Filter and sort repositories: public, not forked, with description
const projects = repos
  .filter(repo => !repo.fork && repo.description && repo.stargazers_count >= 0)
  .sort((a, b) => b.stargazers_count - a.stargazers_count)
  .slice(0, 6);
---

<html lang="zh-CN">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{title} | Suifeng Wudong</title>
		<style>
			:root {
				--bg-color: #ffffff;
				--sidebar-bg: #f8fafc;
				--text-color: #1e293b;
				--text-muted: #64748b;
				--accent-color: #0284c7;
				--border-color: #e2e8f0;
				--max-width: 900px;
			}
			body {
				font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
				line-height: 1.6;
				margin: 0;
				padding: 0;
				background-color: var(--bg-color);
				color: var(--text-color);
			}
			.header {
				background: rgba(255, 255, 255, 0.8);
				backdrop-filter: blur(8px);
				padding: 1rem 2rem;
				border-bottom: 1px solid var(--border-color);
				display: flex;
				justify-content: space-between;
				align-items: center;
				position: sticky;
				top: 0;
				z-index: 100;
			}
			.logo {
				font-size: 1.25rem;
				font-weight: 700;
				color: var(--accent-color);
				text-decoration: none;
			}
			.nav-links {
				display: flex;
				gap: 2rem;
			}
			.nav-links a {
				color: var(--text-muted);
				text-decoration: none;
				font-weight: 500;
				transition: color 0.2s;
			}
			.nav-links a:hover {
				color: var(--accent-color);
			}
			.hero {
				text-align: center;
				padding: 6rem 2rem;
				background: linear-gradient(to bottom, #f8fafc, #ffffff);
				border-bottom: 1px solid var(--border-color);
			}
			.hero h1 {
				font-size: 3.5rem;
				margin: 0;
				font-weight: 800;
				background: linear-gradient(135deg, #0f172a 0%, #0284c7 100%);
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
				letter-spacing: -0.025em;
			}
			.hero p {
				font-size: 1.25rem;
				margin: 1.5rem 0;
				color: var(--text-muted);
				max-width: 600px;
				margin-left: auto;
				margin-right: auto;
			}
			.container {
				max-width: var(--max-width);
				margin: 0 auto;
				padding: 4rem 2rem;
			}
			.section {
				margin-bottom: 4rem;
			}
			.section h2 {
				font-size: 2rem;
				margin-bottom: 2rem;
				color: #0f172a;
			}
			.grid {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
				gap: 1.5rem;
			}
			.card {
				background: white;
				padding: 2rem;
				border-radius: 12px;
				border: 1px solid var(--border-color);
				transition: all 0.2s ease;
				text-decoration: none;
				display: block;
			}
			.card:hover {
				border-color: var(--accent-color);
				box-shadow: 0 10px 30px -10px rgba(2, 132, 199, 0.15);
				transform: translateY(-2px);
			}
			.card h3 {
				margin: 0 0 0.75rem 0;
				font-size: 1.25rem;
				color: var(--text-color);
			}
			.card p {
				margin: 0;
				color: var(--text-muted);
				font-size: 0.9375rem;
			}
			.card .meta {
				display: flex;
				align-items: center;
				justify-content: space-between;
				margin-top: 1.5rem;
				font-size: 0.8125rem;
				font-weight: 600;
				color: var(--accent-color);
				text-transform: uppercase;
				letter-spacing: 0.05em;
			}
			@media (max-width: 640px) {
				.hero h1 { font-size: 2.5rem; }
				.grid { grid-template-columns: 1fr; }
			}
		</style>
	</head>
	<body>
		<header class="header">
			<a href="/" class="logo">Suifeng Wudong</a>
			<nav class="nav-links">
				<a href="/">Home</a>
				<a href="/notes">Notes</a>
				<a href="/about">About</a>
			</nav>
		</header>

		<main>
			<div class="hero">
				<h1>Academic & Engineering</h1>
				<p>知识共享，代码实践，以及关于运筹学、计算机科学的深度思考。</p>
			</div>

			<div class="container">
				<section class="section">
					<h2>最新笔记</h2>
					<div class="grid">
						<a href="/notes/operations-research" class="card">
							<h3>运筹学：确定性方法</h3>
							<p>线性规划、对偶理论、单纯形法以及整数规划的深度解析。包含大量的数学公式与算法实现。</p>
							<div class="meta">查看详情 →</div>
						</a>
						<!-- 可以在这里添加更多笔记 -->
					</div>
				</section>

				<section class="section">
					<h2>开源项目</h2>
					<div class="grid">
						{projects.map(repo => (
							<a href={repo.html_url} class="card" target="_blank" rel="noopener noreferrer">
								<h3>{repo.name}</h3>
								<p>{repo.description}</p>
								<div class="meta">
									<span>⭐ {repo.stargazers_count}</span>
									<span>{repo.language || 'Various'}</span>
								</div>
							</a>
						))}
					</div>
				</section>
			</div>
		</main>
	</body>
</html>